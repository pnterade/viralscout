# ── Data source ───────────────────────────────────────────────
# mock       = built-in fake data, runs with zero keys (great for testing)
# twitterapi = real X/Twitter data via twitterapi.io (pay-as-you-go)
SOURCE=mock

# twitterapi.io credentials (only needed when SOURCE=twitterapi)
TWITTERAPI_BASE_URL=https://api.twitterapi.io
TWITTERAPI_KEY=

# ── Niches to scan ────────────────────────────────────────────
NICHES=memes,animals,politics,crypto,technology
# Optional: override auto-built search queries. Separate multiple with |
# QUERIES=(bitcoin OR solana) min_faves:500 lang:en | (dog OR cat) min_faves:1000

# ── Telegram delivery ─────────────────────────────────────────
# Create a bot with @BotFather, then message your bot and run `npm run demo`
# or use @userinfobot to get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Claude (for categorizing posts into niches) ───────────────
# Optional. Without it, a keyword classifier is used instead.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Behavior tuning ───────────────────────────────────────────
SCAN_INTERVAL_MINUTES=15
MAX_PER_QUERY=30
# Max alerts pushed per scan (top-ranked only, so you aren't spammed)
MAX_ALERTS_PER_SCAN=10
# Share of each batch reserved for "upcoming" posts (0.1 = ~10%, rest already-viral)
UPCOMING_RATIO=0.1
# Search floor: only consider posts with at least this many likes (biases toward big posts)
MIN_FAVES=3000
# Only surface video/gif posts (true/false)
REQUIRE_VIDEO=false

# ── Junk filters ──────────────────────────────────────────────
DROP_GIVEAWAYS=true    # giveaways / airdrops / promos / shill spam
DROP_SELF_PROMO=true   # follow-farming / self-promo / thread-bait
DROP_OFF_TOPIC=false   # drop posts Claude tags "other" (not in your niches)

# Notify when predicted viral probability >= this (0..1) — used for "upcoming"
NOTIFY_THRESHOLD=0.6
# A post is "already viral" at/above this view count
VIRAL_VIEWS=200000
# "Upcoming" = views between this and VIRAL_VIEWS, and rising fast
UPCOMING_MIN_VIEWS=50000
# Use the learned model once we have at least this many labeled outcomes
MIN_TRAIN_SAMPLES=40

# ── Taste (your 👍/👎 feedback) ───────────────────────────────
# Ratings needed before your taste starts shaping the feed
TASTE_MIN_FEEDBACK=5
# Once active, drop posts whose predicted "like" score is below this
TASTE_DROP_THRESHOLD=0.2
# How strongly taste bends ranking (0 = off, 1 = strong)
TASTE_WEIGHT=1
# How long to keep re-checking a post's growth, and when to grade it
TRACK_WINDOW_HOURS=24
LABEL_AFTER_HOURS=24

# ── Database ──────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"
